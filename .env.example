# Copy to .env.local and fill in from the Supabase dashboard (dev project).
# Vercel: set these per environment — preview -> dev project (SUPABASE_ENV=dev),
# production -> prod project (SUPABASE_ENV=prod).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-DEV-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_ENV=dev
