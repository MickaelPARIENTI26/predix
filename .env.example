# Copy to .env.local and fill in from the Supabase dashboard.
# Single environment for now: one Supabase project backs local, previews, and
# the production URL (see docs/decisions.md). Set the same values in Vercel.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Trusted canonical origin for emailed links (confirmation / password reset).
# REQUIRED in production — without it, emailed links fall back to Supabase's
# dashboard Site URL. The app never trusts the request Host header for this.
NEXT_PUBLIC_SITE_URL=https://predix-taupe.vercel.app
